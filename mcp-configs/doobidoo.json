{
  "description": "mcp-memory-service (doobidoo) — semantic search over wiki notes via ChromaDB + Ollama embeddings",
  "silo_scope": ["wiki"],
  "mcpServers": {
    "doobidoo": {
      "command": "python",
      "args": ["-m", "mcp_memory_service"],
      "env": {
        "MCP_MEMORY_SQLITE_PATH": "~/.mewvault/chroma-wiki/memory.db",
        "MCP_MEMORY_BACKUPS_PATH": "~/.mewvault/chroma-wiki-backups",
        "MCP_EXTERNAL_EMBEDDING_URL": "http://localhost:11434/v1/embeddings",
        "MCP_EXTERNAL_EMBEDDING_MODEL": "nomic-embed-text"
      }
    }
  },
  "http_endpoint": null,
  "install": "pip install mcp-memory-service && ollama pull nomic-embed-text"
}
