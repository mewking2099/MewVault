{
  "description": "ChromaDB MCP — semantic search over code and game source files",
  "silo_scope": ["code", "game"],
  "mcpServers": {
    "chromadb": {
      "command": "uvx",
      "args": [
        "chroma-mcp",
        "--client-type", "http",
        "--host", "localhost",
        "--port", "8001",
        "--ssl", "false"
      ],
      "env": {}
    }
  },
  "http_endpoint": "http://localhost:8001",
  "collections": {
    "code": "mewvault-code",
    "game": "mewvault-game"
  },
  "install": "pip install chromadb && uvx chroma-mcp"
}
