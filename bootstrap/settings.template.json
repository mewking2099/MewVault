{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{WORKSPACE}}/mewvault/hooks/session-start.js\"",
            "timeout": 15000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{WORKSPACE}}/mewvault/hooks/session-end.js\"",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{WORKSPACE}}/mewvault/hooks/pre-tool-use.js\"",
            "timeout": 15000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{WORKSPACE}}/mewvault/hooks/agent-track.js\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{WORKSPACE}}/mewvault/hooks/agent-track.js\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{WORKSPACE}}/mewvault/hooks/post-tool-use.js\"",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{WORKSPACE}}/mewvault/hooks/pre-compact.js\"",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
